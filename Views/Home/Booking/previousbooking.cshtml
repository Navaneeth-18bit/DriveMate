@model IEnumerable<adminPage.Models.Booking>

@{
	ViewData["Title"] = "Previous Bookings";
	var selectedUser = ViewBag.SelectedUser as adminPage.Models.User;
	var now = DateTime.Now;
	var recentBookings = Model?.Where(booking => booking.StartTime <= now).OrderByDescending(booking =>
booking.StartTime).ToList() ?? new List<adminPage.Models.Booking>();
	var upcomingBookings = Model?.Where(booking => booking.StartTime > now).OrderBy(booking => booking.StartTime).ToList()
?? new List<adminPage.Models.Booking>();
}

<div class="container py-4">
	<div class="row">
		<div class="col-12">
			<div class="card shadow-sm">
				<div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
					<div>
						<h4 class="mb-0">Previous Bookings</h4>
						@if (selectedUser != null)
						{
							<small>Bookings for @selectedUser.Name (@selectedUser.Email)</small>
						}
					</div>
					<a asp-controller="User" asp-action="Profile" asp-route-id="@(selectedUser?.Id ?? 0)"
					   class="btn btn-light btn-sm">Back to Profile</a>
				</div>
				<div class="card-body">
					<div class="mb-4">
						<h5 class="mb-3">Recent Bookings</h5>
						@if (recentBookings.Any())
						{
							<div class="table-responsive">
								<table class="table table-striped table-bordered align-middle mb-0">
									<thead>
										<tr>
											<th>Booking ID</th>
											<th>Name</th>
											<th>Pickup</th>
											<th>Drop</th>
											<th>Driver</th>
											<th>Start Time</th>
											<th>Status</th>
											<th>Total Amount</th>
											<th>Details</th>
										</tr>
									</thead>
									<tbody>
										@foreach (var booking in recentBookings)
										{
											<tr>
												<td>@booking.BookingId</td>
												<td>@booking.UserName</td>
												<td>@booking.PickupLocation</td>
												<td>@booking.DropLocation</td>
												<td>@(booking.Driver?.Name ?? "-")</td>
												<td>@booking.StartTime.ToString("yyyy-MM-dd HH:mm")</td>
												<td>@booking.Status</td>
												<td>@(booking.TotalAmount?.ToString("0.00") ?? "-")</td>
												<td>
													<a asp-controller="Booking" asp-action="Details"
													   asp-route-id="@booking.BookingId"
													   class="btn btn-sm btn-outline-primary">Details</a>
												</td>
											</tr>
										}
									</tbody>
								</table>
							</div>
						}
						else
						{
							<div class="alert alert-info mb-0">No recent bookings found for this user.</div>
						}
					</div>

					<div>
						<h5 class="mb-3">Upcoming Bookings</h5>
						@if (upcomingBookings.Any())
						{
							<div class="table-responsive">
								<table class="table table-striped table-bordered align-middle mb-0">
									<thead>
										<tr>
											<th>Booking ID</th>
											<th>Name</th>
											<th>Pickup</th>
											<th>Drop</th>
											<th>Driver</th>
											<th>Start Time</th>
											<th>Status</th>
											<th>Total Amount</th>
											<th>Details</th>
										</tr>
									</thead>
									<tbody>
										@foreach (var booking in upcomingBookings)
										{
											<tr>
												<td>@booking.BookingId</td>
												<td>@booking.UserName</td>
												<td>@booking.PickupLocation</td>
												<td>@booking.DropLocation</td>
												<td>@(booking.Driver?.Name ?? "-")</td>
												<td>@booking.StartTime.ToString("yyyy-MM-dd HH:mm")</td>
												<td>@booking.Status</td>
												<td>@(booking.TotalAmount?.ToString("0.00") ?? "-")</td>
												<td>
													<a asp-controller="Booking" asp-action="Details"
													   asp-route-id="@booking.BookingId"
													   class="btn btn-sm btn-outline-primary">Details</a>
												</td>
											</tr>
										}
									</tbody>
								</table>
							</div>
						}
						else
						{
							<div class="alert alert-info mb-0">No upcoming bookings found for this user.</div>
						}
					</div>
				</div>
			</div>
		</div>
	</div>
</div>
