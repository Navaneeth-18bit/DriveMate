@{
    ViewData["Title"] = "About";
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>About - DriveMate</title>

    <meta name="description" content="Learn more about DriveMate and our mission.">

    <link rel="stylesheet" href="~/css/style_about.css">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</head>

<body class="bg-gradient" style="background: linear-gradient(135deg, #0056b3 0%, #0099ff 100%);">

    <main class="main-content">

        <div class="about-section mb-5 text-center">

            <h2 class="title">About Us</h2>

            <p class="section-text mb-5">
                DriveMate is a driver hiring platform designed to connect customers
                with professional and verified drivers for various purposes.
            </p>

        </div>

        <div class="mission text-center mb-5">

            <h2 class="section-title mb-5">Our Mission</h2>

            <p class="section-text">
                Our mission is to make driver hiring simple, safe, and accessible
                for everyone — from individuals to large organizations.
            </p>

        </div>

        <div class="section offer-section">

            <h2 class="offer-heading fs-4 text-center mx-5 mb-5">
                What We Offer
            </h2>

            <ol class="row text-center list-unstyled mt-5 mx-4">

                <li class="col-md-3">Easy Online Booking</li>
                <li class="col-md-3">Transparent Pricing</li>
                <li class="col-md-3">Reliable and Experienced Drivers</li>
                <li class="col-md-3">Dedicated Customer Support</li>

            </ol>

        </div>

    </main>

    <footer class="footer text-center mt-5 p-3">
        <p>&copy; 2026 DriveMate. All rights reserved.</p>
    </footer>

</body>

</html>