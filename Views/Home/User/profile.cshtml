@model adminPage.Models.User

@{
	ViewData["Title"] = "Profile";
}

<div class="container py-4">
	<div class="row justify-content-center">
		<div class="col-12 col-md-10 col-lg-8">
			<div class="card shadow-sm">
				<div class="card-header bg-primary text-white">
					<h4 class="mb-0">Profile Details</h4>
				</div>
				<div class="card-body">
					@if (Model != null)
					{
						<dl class="row mb-0">
							<dt class="col-sm-4">Id</dt>
							<dd class="col-sm-8">@Model.Id</dd>

							<dt class="col-sm-4">Name</dt>
							<dd class="col-sm-8">@Model.Name</dd>

							<dt class="col-sm-4">Email</dt>
							<dd class="col-sm-8">@Model.Email</dd>

							<dt class="col-sm-4">Phone Number</dt>
							<dd class="col-sm-8">@Model.PhoneNumber</dd>

							<dt class="col-sm-4">Date of Birth</dt>
							<dd class="col-sm-8">@Model.DateOfBirth.ToString("yyyy-MM-dd")</dd>

							<dt class="col-sm-4">Created On</dt>
							<dd class="col-sm-8">@Model.CreatedAt</dd>

							<dt class="col-sm-4">Status</dt>
							<dd class="col-sm-8">@(Model.IsActive ? "Active" : "Inactive")</dd>
						</dl>
					}
					else
					{
						<div class="alert alert-info mb-0">No profile details available.</div>
					}

					@if (Model != null)
					{
						<div class="mt-4 d-flex gap-2">
							<a asp-controller="Booking" asp-action="RecentBookings" asp-route-userId="@Model.Id" class="btn btn-outline-primary">
								ViewBookings
							</a>
							<a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
								Back to Dashboard
							</a>
						</div>
					}
				</div>
			</div>
		</div>
	</div>
</div>
