@model adminPage.Models.Driver

@{
    ViewData["Title"] = "Delete Driver";
}

<div class="container mt-4">
    <div class="card shadow-sm rounded-3">
        <div class="card-body">
            <h4 class="fw-bold mb-3">Delete Driver</h4>
            <p>Are you sure you want to delete this driver?</p>

            <div class="mb-3">
                <div><strong>Name:</strong> @Model.Name</div>
                <div><strong>Phone:</strong> @Model.PhoneNumber</div>
                <div><strong>Email:</strong> @Model.Email</div>
                <div><strong>License:</strong> @Model.LicenseNumber</div>
            </div>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="DriverId" />
                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
            </form>
        </div>
    </div>
</div>