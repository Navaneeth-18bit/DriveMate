@model adminPage.Models.Driver

@{
    ViewData["Title"] = "Edit Driver";
}

<div class="container mt-4">
    <div class="card shadow-sm rounded-3">
        <div class="card-body">

            <h4 class="mb-4 fw-bold">Edit Driver</h4>

            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="DriverId" />

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label">Name</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Phone Number</label>
                        <input asp-for="PhoneNumber" class="form-control" />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label">Email</label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">License Number</label>
                        <input asp-for="LicenseNumber" class="form-control" />
                        <span asp-validation-for="LicenseNumber" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label">License Expiry</label>
                        <input asp-for="LicenseExpiry" type="date" class="form-control" />
                        <span asp-validation-for="LicenseExpiry" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Address</label>
                        <input asp-for="Address" class="form-control" />
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="IsAvailable" class="form-check-input" />
                    <label class="form-check-label">Available</label>
                </div>

                <div class="d-flex justify-content-end">
                    <a asp-action="Index" class="btn btn-secondary me-2">Cancel</a>
                    <button type="submit" class="btn btn-primary px-4">Save</button>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}