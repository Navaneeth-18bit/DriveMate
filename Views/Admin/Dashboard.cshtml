@model adminPage.Models.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Admin Dashboard</h2>
            <p class="text-muted mb-0">Manage drivers directly from the dashboard.</p>
        </div>
        <form asp-controller="Admin" asp-action="Logout" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-danger">Logout</button>
        </form>
    </div>

    @if (TempData["DriverCreated"] != null)
    {
        <div class="alert alert-success">@TempData["DriverCreated"]</div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" asp-action="Dashboard" class="row g-3 align-items-end">
                <div class="col-12 col-md-3">
                    <label class="form-label">User Search</label>
                    <input type="text" class="form-control" name="userSearch" value="@Model.UserSearch"
                           placeholder="Name, email, phone" />
                </div>
                <div class="col-12 col-md-2">
                    <label class="form-label">User Status</label>
                    <select class="form-select" name="userStatus">
                        <option value="">All</option>
                        <option value="active" selected="@(Model.UserStatus == "active")">Active</option>
                        <option value="inactive" selected="@(Model.UserStatus == "inactive")">Inactive</option>
                    </select>
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label">Booking Search</label>
                    <input type="text" class="form-control" name="bookingSearch" value="@Model.BookingSearch"
                           placeholder="Booking ID, user, driver" />
                </div>
                <div class="col-12 col-md-2">
                    <label class="form-label">Booking Status</label>
                    <select class="form-select" name="bookingStatus">
                        <option value="">All</option>
                        <option value="Pending" selected="@(Model.BookingStatus == "Pending")">Pending</option>
                        <option value="Accepted" selected="@(Model.BookingStatus == "Accepted")">Accepted</option>
                        <option value="Completed" selected="@(Model.BookingStatus == "Completed")">Completed</option>
                        <option value="Cancelled" selected="@(Model.BookingStatus == "Cancelled")">Cancelled</option>
                    </select>
                </div>
                <div class="col-12 col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-primary w-100">Apply</button>
                    <a asp-action="Dashboard" class="btn btn-outline-secondary w-100">Reset</a>
                </div>
            </form>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12 col-md-4">
            <div class="alert alert-light border mb-0">
                Users: @Model.TotalUsers total, page @Model.UserPage of @Model.TotalUserPages
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="alert alert-light border mb-0">
                Bookings: @Model.TotalBookings total, page @Model.BookingPage of @Model.TotalBookingPages
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="alert alert-light border mb-0">
                Drivers: @Model.TotalDrivers total, page @Model.DriverPage of @Model.TotalDriverPages
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12 col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-primary text-white">
                    <strong>Add Driver</strong>
                </div>
                <div class="card-body">
                    <form asp-action="CreateDriver" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="NewDriver.Name" class="form-label"></label>
                            <input asp-for="NewDriver.Name" class="form-control" />
                            <span asp-validation-for="NewDriver.Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NewDriver.PhoneNumber" class="form-label"></label>
                            <input asp-for="NewDriver.PhoneNumber" class="form-control" />
                            <span asp-validation-for="NewDriver.PhoneNumber" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NewDriver.Email" class="form-label"></label>
                            <input asp-for="NewDriver.Email" class="form-control" />
                            <span asp-validation-for="NewDriver.Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NewDriver.LicenseNumber" class="form-label"></label>
                            <input asp-for="NewDriver.LicenseNumber" class="form-control" />
                            <span asp-validation-for="NewDriver.LicenseNumber" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NewDriver.Experience" class="form-label"></label>
                            <input asp-for="NewDriver.Experience" type="number" min="0" max="60" class="form-control" />
                            <span asp-validation-for="NewDriver.Experience" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NewDriver.LicenseExpiry" class="form-label"></label>
                            <input asp-for="NewDriver.LicenseExpiry" type="date" class="form-control" />
                            <span asp-validation-for="NewDriver.LicenseExpiry" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NewDriver.Address" class="form-label"></label>
                            <textarea asp-for="NewDriver.Address" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="NewDriver.Address" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Insert Driver</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white">
                    <strong>Drivers Table</strong>
                </div>
                <div class="card-body table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Name</th>
                                <th>Phone</th>
                                <th>Email</th>
                                <th>License</th>
                                <th>Expiry</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model?.Drivers != null && Model.Drivers.Any())
                            {
                                foreach (var driver in Model.Drivers)
                                {
                                    <tr>
                                        <td>@driver.Name</td>
                                        <td>@driver.PhoneNumber</td>
                                        <td>@driver.Email</td>
                                        <td>@driver.LicenseNumber</td>
                                        <td>@driver.LicenseExpiry.ToString("dd MMM yyyy")</td>
                                        <td>
                                            <span class="badge @(driver.IsAvailable ? "bg-success" : "bg-secondary")">
                                                @(driver.IsAvailable ? "Available" : "Unavailable")
                                            </span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-4">No drivers found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <span class="text-muted small">Page @Model.DriverPage of @Model.TotalDriverPages</span>
                        <div class="btn-group">
                            <a class="btn btn-outline-secondary btn-sm @(Model.DriverPage <= 1 ? "disabled" : string.Empty)"
                               asp-action="Dashboard" asp-route-userSearch="@Model.UserSearch"
                               asp-route-userStatus="@Model.UserStatus" asp-route-bookingSearch="@Model.BookingSearch"
                               asp-route-bookingStatus="@Model.BookingStatus" asp-route-userPage="@Model.UserPage"
                               asp-route-bookingPage="@Model.BookingPage"
                               asp-route-driverPage="@(Model.DriverPage - 1)">
                                Previous
                            </a>
                            <a class="btn btn-outline-secondary btn-sm @(Model.DriverPage >= Model.TotalDriverPages ? "disabled" : string.Empty)"
                               asp-action="Dashboard" asp-route-userSearch="@Model.UserSearch"
                               asp-route-userStatus="@Model.UserStatus" asp-route-bookingSearch="@Model.BookingSearch"
                               asp-route-bookingStatus="@Model.BookingStatus" asp-route-userPage="@Model.UserPage"
                               asp-route-bookingPage="@Model.BookingPage"
                               asp-route-driverPage="@(Model.DriverPage + 1)">
                                Next
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-1">
        <div class="col-12 col-lg-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-info text-white">
                    <strong>Users Table</strong>
                </div>
                <div class="card-body table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model?.Users != null && Model.Users.Any())
                            {
                                foreach (var user in Model.Users)
                                {
                                    <tr>
                                        <td>@user.Name</td>
                                        <td>@user.Email</td>
                                        <td>@user.PhoneNumber</td>
                                        <td>
                                            <span class="badge @(user.IsActive ? "bg-success" : "bg-secondary")">
                                                @(user.IsActive ? "Active" : "Inactive")
                                            </span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-4">No users found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <span class="text-muted small">Page @Model.UserPage of @Model.TotalUserPages</span>
                        <div class="btn-group">
                            <a class="btn btn-outline-secondary btn-sm @(Model.UserPage <= 1 ? "disabled" : string.Empty)"
                               asp-action="Dashboard" asp-route-userSearch="@Model.UserSearch"
                               asp-route-userStatus="@Model.UserStatus" asp-route-bookingSearch="@Model.BookingSearch"
                               asp-route-bookingStatus="@Model.BookingStatus"
                               asp-route-userPage="@(Model.UserPage - 1)" asp-route-bookingPage="@Model.BookingPage"
                               asp-route-driverPage="@Model.DriverPage">
                                Previous
                            </a>
                            <a class="btn btn-outline-secondary btn-sm @(Model.UserPage >= Model.TotalUserPages ? "disabled" : string.Empty)"
                               asp-action="Dashboard" asp-route-userSearch="@Model.UserSearch"
                               asp-route-userStatus="@Model.UserStatus" asp-route-bookingSearch="@Model.BookingSearch"
                               asp-route-bookingStatus="@Model.BookingStatus"
                               asp-route-userPage="@(Model.UserPage + 1)" asp-route-bookingPage="@Model.BookingPage"
                               asp-route-driverPage="@Model.DriverPage">
                                Next
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-success text-white">
                    <strong>Bookings Table</strong>
                </div>
                <div class="card-body table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>User</th>
                                <th>Driver</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model?.Bookings != null && Model.Bookings.Any())
                            {
                                foreach (var booking in Model.Bookings)
                                {
                                    <tr>
                                        <td>@booking.BookingId</td>
                                        <td>@booking.UserName</td>
                                        <td>@booking.User?.Name</td>
                                        <td>@booking.Driver?.Name</td>
                                        <td>@booking.Status</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-4">No bookings found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <span class="text-muted small">Page @Model.BookingPage of @Model.TotalBookingPages</span>
                        <div class="btn-group">
                            <a class="btn btn-outline-secondary btn-sm @(Model.BookingPage <= 1 ? "disabled" : string.Empty)"
                               asp-action="Dashboard" asp-route-userSearch="@Model.UserSearch"
                               asp-route-userStatus="@Model.UserStatus" asp-route-bookingSearch="@Model.BookingSearch"
                               asp-route-bookingStatus="@Model.BookingStatus" asp-route-userPage="@Model.UserPage"
                               asp-route-bookingPage="@(Model.BookingPage - 1)"
                               asp-route-driverPage="@Model.DriverPage">
                                Previous
                            </a>
                            <a class="btn btn-outline-secondary btn-sm @(Model.BookingPage >= Model.TotalBookingPages ? "disabled" : string.Empty)"
                               asp-action="Dashboard" asp-route-userSearch="@Model.UserSearch"
                               asp-route-userStatus="@Model.UserStatus" asp-route-bookingSearch="@Model.BookingSearch"
                               asp-route-bookingStatus="@Model.BookingStatus" asp-route-userPage="@Model.UserPage"
                               asp-route-bookingPage="@(Model.BookingPage + 1)"
                               asp-route-driverPage="@Model.DriverPage">
                                Next
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
