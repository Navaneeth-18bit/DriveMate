@model adminPage.Models.Booking

@{
    ViewData["Title"] = "Booking Details";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-12 col-md-10 col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">Booking Details</h4>
                    <a asp-controller="Booking" asp-action="RecentBookings" asp-route-userId="@Model.UserId"
                       class="btn btn-light btn-sm">Back to Bookings</a>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Booking ID</dt>
                        <dd class="col-sm-8">@Model.BookingId</dd>

                        <dt class="col-sm-4">Name</dt>
                        <dd class="col-sm-8">@Model.UserName</dd>

                        <dt class="col-sm-4">User</dt>
                        <dd class="col-sm-8">@Model.User?.Name (@Model.User?.Email)</dd>

                        <dt class="col-sm-4">Driver</dt>
                        <dd class="col-sm-8">@Model.Driver?.Name</dd>

                        <dt class="col-sm-4">Pickup Location</dt>
                        <dd class="col-sm-8">@Model.PickupLocation</dd>

                        <dt class="col-sm-4">Drop Location</dt>
                        <dd class="col-sm-8">@Model.DropLocation</dd>

                        <dt class="col-sm-4">Start Time</dt>
                        <dd class="col-sm-8">@Model.StartTime.ToString("yyyy-MM-dd HH:mm")</dd>

                        <dt class="col-sm-4">End Time</dt>
                        <dd class="col-sm-8">@(Model.EndTime.HasValue? Model.EndTime.Value.ToString("yyyy-MM-dd HH:mm")
                                                                                                                            : "-")</dd>

                            <dt class="col-sm-4">Status</dt>
                            <dd class="col-sm-8">@Model.Status</dd>

                            <dt class="col-sm-4">Total Amount</dt>
                            <dd class="col-sm-8">@(Model.TotalAmount?.ToString("0.00") ?? "-")</dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>
    </div>