@model IEnumerable<adminPage.Models.Booking>

@{
    ViewData["Title"] = "Recent Bookings";
    var selectedUser = ViewBag.SelectedUser as adminPage.Models.User;
    var now = DateTime.Now;
    var recentBookings = Model?.Where(booking =>
            booking.Status == "Completed" ||
            booking.Status == "Cancelled" ||
            booking.StartTime <= now)
        .OrderByDescending(booking => booking.StartTime)
        .ToList() ?? new List<adminPage.Models.Booking>();
    var upcomingBookings = Model?.Where(booking =>
            booking.StartTime > now &&
            booking.Status != "Completed" &&
            booking.Status != "Cancelled")
        .OrderBy(booking => booking.StartTime)
        .ToList() ?? new List<adminPage.Models.Booking>();
}

<div class="container py-4">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <div>
                        <h4 class="mb-0">Recent Bookings</h4>
                        @if (selectedUser != null)
                        {
                            <small>Bookings for @selectedUser.Name (@selectedUser.Email)</small>
                        }
                    </div>
                    <a asp-controller="User" asp-action="Profile" asp-route-id="@(selectedUser?.Id ?? 0)"
                       class="btn btn-light btn-sm">Back to Profile</a>
                </div>
                <div class="card-body">
                    <div class="mb-4">
                        <h5 class="mb-3">Recent Bookings</h5>
                        @if (recentBookings.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-striped table-bordered align-middle mb-0">
                                    <thead>
                                        <tr>
                                            <th>Booking ID</th>
                                            <th>Name</th>
                                            <th>Pickup</th>
                                            <th>Drop</th>
                                            <th>Driver</th>
                                            <th>Start Time</th>
                                            <th>Status</th>
                                            <th>Total Amount</th>
                                            <th>Details</th>
                                            <th>Finish Ride</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var booking in recentBookings)
                                        {
                                            <tr>
                                                <td>@booking.BookingId</td>
                                                <td>@booking.UserName</td>
                                                <td>@booking.PickupLocation</td>
                                                <td>@booking.DropLocation</td>
                                                <td>@(booking.Driver?.Name ?? "-")</td>
                                                <td>@booking.StartTime.ToString("yyyy-MM-dd HH:mm")</td>
                                                <td>@booking.Status</td>
                                                <td>@(booking.TotalAmount?.ToString("0.00") ?? "-")</td>
                                                <td>
                                                    <a asp-controller="Booking" asp-action="Details"
                                                       asp-route-id="@booking.BookingId"
                                                       class="btn btn-sm btn-outline-primary">Details</a>
                                                </td>
                                                <td>
                                                    @if (booking.Status != "Completed" && booking.Status != "Cancelled")
                                                    {
                                                        <button type="button" class="btn btn-sm btn-success" data-bs-toggle="modal"
                                                                data-bs-target="#finishRideModal" data-booking-id="@booking.BookingId"
                                                                data-booking-drop="@(booking.DropLocation ?? string.Empty)"
                                                                data-booking-end="@(booking.EndTime?.ToString("yyyy-MM-ddTHH:mm") ?? DateTime.Now.ToString("yyyy-MM-ddTHH:mm"))">
                                                            Finish ride
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">Done</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info mb-0">No recent bookings found for this user.</div>
                        }
                    </div>

                    <div>
                        <h5 class="mb-3">Upcoming Bookings</h5>
                        @if (upcomingBookings.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-striped table-bordered align-middle mb-0">
                                    <thead>
                                        <tr>
                                            <th>Booking ID</th>
                                            <th>Name</th>
                                            <th>Pickup</th>
                                            <th>Drop</th>
                                            <th>Driver</th>
                                            <th>Start Time</th>
                                            <th>Status</th>
                                            <th>Total Amount</th>
                                            <th>Details</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var booking in upcomingBookings)
                                        {
                                            <tr>
                                                <td>@booking.BookingId</td>
                                                <td>@booking.UserName</td>
                                                <td>@booking.PickupLocation</td>
                                                <td>@booking.DropLocation</td>
                                                <td>@(booking.Driver?.Name ?? "-")</td>
                                                <td>@booking.StartTime.ToString("yyyy-MM-dd HH:mm")</td>
                                                <td>@booking.Status</td>
                                                <td>@(booking.TotalAmount?.ToString("0.00") ?? "-")</td>
                                                <td>
                                                    <a asp-controller="Booking" asp-action="Details"
                                                       asp-route-id="@booking.BookingId"
                                                       class="btn btn-sm btn-outline-primary">Details</a>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info mb-0">No upcoming bookings found for this user.</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="finishRideModal" tabindex="-1" aria-labelledby="finishRideModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="finishRideModalLabel">Finish Ride</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                        aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form asp-controller="Booking" asp-action="FinishRide" method="post" id="finishRideForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="bookingId" id="finishBookingId" />


                    <div class="mb-3">
                        <label for="finishEndTime" class="form-label">End Time</label>
                        <input type="datetime-local" class="form-control" name="endTime" id="finishEndTime" required />
                    </div>

                    <p class="text-muted mb-0">Finishing the ride will mark the driver as available again.</p>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" form="finishRideForm" class="btn btn-success">Save and Finish</button>
            </div>
        </div>
    </div>
</div>

<script>
    const finishRideModal = document.getElementById('finishRideModal');
    if (finishRideModal) {
        finishRideModal.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            const bookingId = button.getAttribute('data-booking-id');
            const dropLocation = button.getAttribute('data-booking-drop') || '';
            const endTime = button.getAttribute('data-booking-end') || '';

            document.getElementById('finishBookingId').value = bookingId;
            document.getElementById('finishDropLocation').value = dropLocation;
            document.getElementById('finishEndTime').value = endTime;
        });
    }
</script>